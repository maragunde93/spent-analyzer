SPENT_DATABASE_URL=postgresql+psycopg://spent:spent_dev_password@localhost:5432/spent_analyzer
SPENT_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
SPENT_TEST_AUTH_ENABLED=true
SPENT_PUBLIC_BASE_URL=http://localhost:8080
SPENT_PUBLIC_API_BASE_URL=http://localhost:8080/api
SPENT_GOOGLE_CLIENT_ID=
SPENT_GOOGLE_CLIENT_SECRET=
SPENT_ALLOWED_GOOGLE_EMAILS=[]
SPENT_LOCAL_USERS=[]
SPENT_SESSION_SECRET=replace-this-for-homelab
SPENT_SESSION_COOKIE_PATH=/
SPENT_SESSION_COOKIE_SECURE=false
SPENT_SESSION_COOKIE_SAMESITE=lax
SPENT_FX_AUTO_UPDATE_ENABLED=true
SPENT_FX_API_URL=https://dolarapi.com/v1/dolares/blue
SPENT_FX_UPDATE_HOUR_ARGENTINA=11

# Production docker-compose.prod.yml
SPENT_POSTGRES_DB=spent_analyzer
SPENT_POSTGRES_USER=spent
SPENT_POSTGRES_PASSWORD=replace-this-db-password
# Production example values:
# SPENT_CORS_ORIGINS=["https://homelab.local"]
# SPENT_PUBLIC_BASE_URL=https://homelab.local/finance
# SPENT_PUBLIC_API_BASE_URL=https://homelab.local/finance/api
# Values containing literal dollar signs must be single-quoted in production .env
# files so Docker Compose does not treat those fragments as variable references.
# Password hashes commonly contain dollar signs, so keep this JSON single-quoted.
# SPENT_LOCAL_USERS='[{"username":"mauro","email":"mauro@example.test","display_name":"Mauro","password_hash":"pbkdf2_sha256$260000$..."}]'
# SPENT_SESSION_COOKIE_PATH=/finance
# SPENT_SESSION_COOKIE_SECURE=true
